{
  "lines": [
    {
      "components": ["model", "version", "directory", "git"],
      "separator": " | "
    },
    {
      "components": ["progress_bar", "tokens", "tokens_cached"],
      "separator": " | "
    },
    {
      "components": ["cost", "duration", "lines_changed"],
      "separator": " | "
    },
    {
      "components": ["weekly_usage", "block_timer"],
      "separator": " | "
    }
  ],
  "progress_bar": {
    "width": 12,
    "filled_char": "█",
    "empty_char": "░",
    "show_percentage": true
  },
  "colors": {
    "enabled": true,
    "low": {"threshold": 50, "color": "green"},
    "medium": {"threshold": 75, "color": "yellow"},
    "high": {"threshold": 90, "color": "red"}
  },
  "tokens": {
    "format": "↑{input} ↓{output} Σ{total}",
    "unit": "auto"
  },
  "components": {
    "model": {"format": "🤖 {name}"},
    "version": {"format": "v{version}"},
    "directory": {"max_length": 30, "show_git_root": true},
    "git": {"show_branch": true, "show_changes": true},
    "cost": {"format": "💰 ${cost}"},
    "duration": {"format": "⏱ {duration}"},
    "tokens_cached": {"format": "📦 {cached}", "unit": "auto"},
    "lines_changed": {"format": "+{added} -{removed}"},
    "custom_text": {"text": "", "color": "cyan"},
    "weekly_usage": {"format": "📅 {percent:.1f}%", "show_progress": false},
    "block_timer": {"format": "⏰ {elapsed}", "show_progress": false, "show_remaining": false}
  }
}
