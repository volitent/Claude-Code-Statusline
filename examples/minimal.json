{
  "lines": [
    {
      "components": ["progress_bar", "model"],
      "separator": " "
    }
  ],
  "progress_bar": {
    "width": 8,
    "filled_char": "█",
    "empty_char": "░",
    "gradient_char": "▓",
    "show_percentage": true
  },
  "colors": {
    "enabled": true,
    "low": {"threshold": 50, "color": "green"},
    "medium": {"threshold": 75, "color": "yellow"},
    "high": {"threshold": 90, "color": "red"}
  },
  "tokens": {
    "format": "{total}",
    "unit": "k"
  },
  "components": {
    "model": {"format": "{name}"}
  }
}
