{
  "lines": [
    {
      "components": ["model", "directory", "git"],
      "separator": " | "
    },
    {
      "components": ["progress_bar", "tokens", "cost", "duration"],
      "separator": " | "
    }
  ],
  "progress_bar": {
    "width": 20,
    "filled_char": "▓",
    "empty_char": "░",
    "gradient_char": "▒"
  },
  "colors": {
    "enabled": true,
    "low": {"threshold": 40, "color": "green"},
    "medium": {"threshold": 70, "color": "yellow"},
    "high": {"threshold": 85, "color": "red"}
  },
  "tokens": {
    "format": "In: {input} | Out: {output} | Total: {total}",
    "unit": "k"
  },
  "components": {
    "model": {"format": "[{name}]"},
    "directory": {"max_length": 25, "show_git_root": true},
    "git": {"show_branch": true, "show_changes": true},
    "cost": {"format": "Cost: ${cost}"},
    "duration": {"format": "Time: {duration}"}
  }
}
